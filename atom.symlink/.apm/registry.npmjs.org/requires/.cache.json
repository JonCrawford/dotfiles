g\": \"require(\\\"something\\\")\",\n    \"path\": \"something\",\n    \"index\": 79\n  }\n]\n```\n\n# License\n\n  MIT","maintainers":[{"name":"tjholowaychuk","email":"tj@vision-media.ca"}],"time":{"modified":"2014-10-07T23:51:38.511Z","created":"2013-11-14T18:03:45.699Z","0.0.1":"2013-11-14T18:03:47.836Z","1.0.0":"2013-11-14T18:30:07.543Z","1.0.1":"2014-04-10T15:00:48.475Z","1.0.2":"2014-10-07T23:51:38.511Z"},"repository":{"type":"git","url":"git://github.com/visionmedia/node-requires"},"homepage":"https://github.com/visionmedia/node-requires","keywords":["require"],"bugs":{"url":"https://github.com/visionmedia/node-requires/issues"},"license":"MIT","readmeFilename":"Readme.md","_attachments":{},"_etag":"\"EIY4HVS4FVVTHUGOTRD0W19QP\""}